# Tmuxinator aliases
# mux is provided by oh-my-zsh tmuxinator plugin — these extend it

alias muxl="tmuxinator list"         # List all projects
alias muxn="tmuxinator new"          # Create new project
alias muxe="tmuxinator edit"         # Edit project config
alias muxd="tmuxinator delete"       # Delete project
alias muxc="tmuxinator copy"         # Copy project
alias muxo="tmuxinator open"         # Open project in editor
