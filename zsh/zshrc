# ~/.zshrc - Main Zsh configuration
# Managed by dotfiles. Machine-specific overrides go in ~/.zshrc.local

# --- Oh-My-Zsh Setup ---
export ZSH="${HOME}/.oh-my-zsh"
ZSH_THEME="robbyrussell"

# Plugins (built-in oh-my-zsh plugins)
plugins=(
  git
  z
  docker
  kubectl
  fzf
)

# Custom plugins installed as git submodules
ZSH_CUSTOM="${ZSH_CUSTOM:-$ZSH/custom}"

# Source oh-my-zsh (skip if not installed)
if [[ -f "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

# --- History Configuration ---
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000

setopt HIST_IGNORE_DUPS       # Don't record duplicate entries
setopt HIST_IGNORE_ALL_DUPS   # Remove older duplicate entries
setopt HIST_FIND_NO_DUPS      # Don't show duplicates in search
setopt HIST_REDUCE_BLANKS     # Remove extra blanks from commands
setopt HIST_IGNORE_SPACE      # Don't record commands starting with space
setopt SHARE_HISTORY          # Share history across sessions
setopt APPEND_HISTORY         # Append to history file
setopt INC_APPEND_HISTORY     # Write immediately, not on shell exit
setopt EXTENDED_HISTORY       # Record timestamp in history

# --- PATH ---
typeset -U path  # Deduplicate PATH entries
path=(
  "${HOME}/.local/bin"
  "${HOME}/bin"
  $path
)
export PATH

# --- Exports ---
export EDITOR="${EDITOR:-vim}"
export VISUAL="${VISUAL:-vim}"
export PAGER="${PAGER:-less}"
export LANG="${LANG:-en_US.UTF-8}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# Less options: raw control chars, case-insensitive search, quit if one screen
export LESS="-R -i -F -X"

# --- Source Modular Configs ---
for config_file in "${HOME}/.zsh/aliases/"*.zsh(N); do
  source "$config_file"
done

for config_file in "${HOME}/.zsh/functions/"*.zsh(N); do
  source "$config_file"
done

# --- External Plugins (git submodules) ---
# These are sourced after oh-my-zsh so they can override/extend behavior
_dotfiles_dir="${${(%):-%x}:A:h}"
if [[ -f "${_dotfiles_dir}/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" ]]; then
  source "${_dotfiles_dir}/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi
# Syntax highlighting must be sourced last
if [[ -f "${_dotfiles_dir}/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]]; then
  source "${_dotfiles_dir}/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi
unset _dotfiles_dir

# --- Machine-Specific Overrides ---
if [[ -f "${HOME}/.zshrc.local" ]]; then
  source "${HOME}/.zshrc.local"
fi
