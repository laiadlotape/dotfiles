#!/usr/bin/env bash
#
# tmux-sessionizer — aesthetic fzf session picker for tmux
#
# Bound to Alt+s in tmux.conf. Lists all tmux sessions with a live
# pane-content preview. Supports mouse wheel and PgUp/PgDn scrolling
# in the preview pane.
#
# Works for both:
#   - Switching between sessions (when already attached)
#   - Attaching to a session (when detached)

set -euo pipefail

# Bail if tmux isn't running
if ! tmux list-sessions &>/dev/null; then
  echo "No tmux sessions running." >&2
  exit 0
fi

current_session=""
if [ -n "${TMUX:-}" ]; then
  current_session="$(tmux display-message -p '#S')"
fi

# Preview: capture visible pane content from the target session's active window
preview_cmd='
  session={}
  # Strip everything after the colon (fzf formatting)
  session="${session%%:*}"
  # Capture the active pane of that session
  tmux capture-pane -t "$session" -p -e 2>/dev/null || echo "(no preview available)"
'

selected=$(
  tmux list-sessions -F "#{session_name}: #{session_windows} windows (#{session_attached} attached)" |
  fzf \
    --reverse \
    --border rounded \
    --border-label " tmux sessions " \
    --border-label-pos 2 \
    --info inline \
    --header "current: ${current_session:-<detached>}" \
    --prompt "session ▶ " \
    --pointer "▶" \
    --preview "$preview_cmd" \
    --preview-window "right:60%:wrap" \
    --bind "page-up:preview-half-page-up,page-down:preview-half-page-down" \
    --color "fg:-1,bg:-1,hl:#5f87af,fg+:#d0d0d0,bg+:#262626,hl+:#5fd7ff" \
    --color "info:#afaf87,prompt:#d7005f,pointer:#af5fff,marker:#87ff00,spinner:#af5fff,header:#87afaf,border:#7aa2f7,label:#e0af68" \
    --no-mouse \
  || true
)

# Nothing selected (user pressed Escape)
if [ -z "$selected" ]; then
  exit 0
fi

# Extract session name (before the colon)
target="${selected%%:*}"

if [ -n "${TMUX:-}" ]; then
  # Already inside tmux — switch client
  tmux switch-client -t "$target"
else
  # Outside tmux — attach
  tmux attach-session -t "$target"
fi
