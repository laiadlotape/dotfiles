#!/usr/bin/env bash
#
# tmux-sessionizer — polished fzf session navigator for tmux
#
# Bound to Alt+q in tmux.conf. Lists all tmux sessions with rich info
# and a full-scrollback pane preview. Adaptive layout based on terminal size.
#
# Works for both:
#   - Switching between sessions (when already attached)
#   - Attaching to a session (when detached)

set -euo pipefail

# Bail if tmux isn't running
if ! tmux list-sessions &>/dev/null; then
  echo "No tmux sessions running." >&2
  sleep 1 # Give user a moment to read the message
  exit 0
fi

current_session=""
if [ -n "${TMUX:-}" ]; then
  current_session="$(tmux display-message -p '#S')"
fi

# Preview: right side 70% width, scroll to bottom — leaves session list visible on left
preview_pos="right:80%:wrap:follow"

# Preview: capture full scrollback with session info header
preview_cmd='
  session={}
  session="${session%%:*}"
  cwd=$(tmux display-message -t "$session" -p "#{pane_current_path}" 2>/dev/null || echo "?")
  cmd=$(tmux display-message -t "$session" -p "#{pane_current_command}" 2>/dev/null || echo "?")
  icon="${THEME_EMOJI_SESSION_POINTER:-▶}"
  printf "\033[1;35m%s %s\033[0m  \033[0;36m%s\033[0m  \033[0;33m(%s)\033[0m\n" "$icon" "$session" "$cwd" "$cmd"
  echo "────────────────────────────────────────────"
  tmux capture-pane -t "$session" -p -e -J -S - 2>/dev/null || echo "(no preview available)"
'

# Theme-aware sessionizer status symbols
_cur_marker="${THEME_EMOJI_SESSION_CURRENT:-◆}"
_att_sym="${THEME_EMOJI_SESSION_ATTACHED:-attached}"
_age_sym="${THEME_EMOJI_SESSION_AGE:-}"

# Rich session list: name, window count, attached status, age, cwd
session_list=$(
  tmux list-sessions -F '#{session_name}:#{session_windows}:#{session_attached}:#{session_created}:#{pane_current_path}' 2>/dev/null |
  awk -v now="$(date +%s)" -v cur="$current_session" \
      -v cur_marker="$_cur_marker" \
      -v att_sym="$_att_sym" \
      -v age_sym="$_age_sym" \
      -F: '{
    name=$1; wins=$2; att=$3; created=$4
    cwd=""
    for (i=5; i<=NF; i++) cwd = (cwd == "" ? $i : cwd ":" $i)
    age = now - created
    if (age < 60)         { unit = "s" }
    else if (age < 3600)  { age = int(age/60);   unit = "m" }
    else if (age < 86400) { age = int(age/3600);  unit = "h" }
    else                  { age = int(age/86400); unit = "d" }
    attached = (att > 0) ? " " att_sym : ""
    marker   = (name == cur) ? " " cur_marker : ""
    age_pfx  = (age_sym != "") ? age_sym " " : ""
    printf "%s: %dw%s %s%d%s ago  %s%s\n", name, wins, attached, age_pfx, age, unit, cwd, marker
  }'
)

header_text="current: ${current_session:-<detached>}"$'\n'"Enter:go Esc:quit ?:preview"$'\n'"PgUp/Dn:scroll Home/End:jump"$'\n'"Alt+p:toggle Alt+w:cycle"

# Use theme emoji pack if available, fall back to plain symbols
_session_prompt="${THEME_EMOJI_SESSION_PROMPT:-session ▶ }"
_session_pointer="${THEME_EMOJI_SESSION_POINTER:-▶}"
_fzf_colors="${THEME_FZF_COLORS:-fg:-1,bg:-1,hl:#5f87af,fg+:#d0d0d0,bg+:#262626,hl+:#5fd7ff,info:#afaf87,prompt:#5f87af,pointer:#af5fff,marker:#87ff00,spinner:#af5fff,header:#87afaf,border:#3a3a3a,gutter:-1}"

selected=$(
  echo "$session_list" |
  fzf \
    --reverse \
    --border rounded \
    --border-label " $_cur_marker tmux sessions " \
    --border-label-pos 2 \
    --info inline \
    --header "$header_text" \
    --prompt "$_session_prompt" \
    --pointer "$_session_pointer" \
    --preview "$preview_cmd" \
    --preview-window "$preview_pos" \
    --height 100% \
    --bind "page-up:preview-half-page-up,page-down:preview-half-page-down" \
    --bind "home:preview-top,end:preview-bottom" \
    --bind "alt-p:toggle-preview,alt-w:change-preview-window(right:70%|right:50%|down:80%|hidden)" \
    --bind "?:toggle-preview" \
    --cycle \
    --no-mouse \
    --color "$_fzf_colors" \
  || true
)
unset _session_prompt _session_pointer _fzf_colors _cur_marker _att_sym _age_sym

# Nothing selected (user pressed Escape)
if [ -z "$selected" ]; then
  exit 0
fi

# Extract session name (before the colon)
target="${selected%%:*}"

if [ -n "${TMUX:-}" ]; then
  # Already inside tmux — switch client
  tmux switch-client -t "$target"
else
  # Outside tmux — exec replaces this process so tmux gets full terminal control
  exec </dev/tty
  exec <&1
  exec tmux attach-session -t "$target"
fi
